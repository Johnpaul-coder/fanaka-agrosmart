# ==========================================
# FANAKA AGROSMART - BACKEND ENVIRONMENT VARIABLES
# ==========================================

# --- 1. DATABASE CONFIGURATION ---
# For local development (Use this right now):
DATABASE_URL="sqlite:///./fanaka_dev.db"
# For production later (e.g., Supabase / PostgreSQL):
# DATABASE_URL="postgresql://user:password@localhost:5432/fanaka_db"

# --- 2. SECURITY & AUTHENTICATION ---
# The secret key used to encrypt user login sessions (Keep this very safe!)
SECRET_KEY="your_super_secret_random_string_here"
# The algorithm used for JWT tokens
ALGORITHM="HS256"
# How long a farmer stays logged in before needing to enter OTP again (in minutes)
ACCESS_TOKEN_EXPIRE_MINUTES=10080 

# --- 3. M-PESA DARAJA API (SAFARICOM) ---
# Your consumer keys from the Safaricom Developer Portal
MPESA_CONSUMER_KEY="your_test_consumer_key_here"
MPESA_CONSUMER_SECRET="your_test_consumer_secret_here"
# The Paybill/Till number (174379 is the default Sandbox Shortcode)
MPESA_SHORTCODE="174379"
# The Passkey for STK Push verification
MPESA_PASSKEY="your_test_passkey_here"

# --- 4. AI SCANNER CONFIGURATION ---
# The exact folder path where your trained plant disease model lives
AI_MODEL_PATH="./ai_models/crop_disease_v1.h5"

# --- 5. CORS (CROSS-ORIGIN RESOURCE SHARING) ---
# Tells the backend to only accept requests from your specific Next.js frontend
FRONTEND_URL="http://localhost:3000"